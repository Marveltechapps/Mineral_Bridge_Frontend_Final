## Expo app environment (local development)
#
# Play Store / App Store (EAS production): set EXPO_PUBLIC_API_BASE_URL to a public **https://** API URL so the app
# disables cleartext traffic in the release build (see app.config.js).
#
# For a real phone over Wi‑Fi, prefer an HTTPS tunnel URL (ngrok/cloudflare) to avoid Android HTTP cleartext issues.
# Example:
# EXPO_PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.app
#
# For Android emulator with EXPO_PUBLIC_API_BASE_URL=http://localhost:5000, the app rewrites localhost → 10.0.2.2 at runtime.
#
# Default: backend on this machine, port 5000.
# - Android emulator: localhost → 10.0.2.2 at runtime.
# - Physical phone (Expo Go / dev client, __DEV__, LAN): localhost → same LAN IP as Metro when detectable.
# If auto-detection fails (e.g. tunnel-only), set your PC's LAN IP or HTTPS tunnel (see .env.phone.example).
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Optional: your LAN IP for the Metro bundler (Expo QR / LAN mode)
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.x.x

# Optional: request timeout in ms
EXPO_PUBLIC_API_TIMEOUT=60000

# Optional: maps key
EXPO_PUBLIC_GOOGLE_MAPS_TOKEN=
