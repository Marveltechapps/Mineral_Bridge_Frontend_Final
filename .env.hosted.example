## Copy to .env when using hosted backend (EC2) + Expo Go on a real phone
## Replace 15.207.119.50 with your server IP. Replace 192.168.x.x with your PC LAN IP (see backend terminal: "Network: http://...").
EXPO_PUBLIC_API_BASE_URL=http://15.207.119.50:5000
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.15
EXPO_PUBLIC_API_TIMEOUT=60000
EXPO_PUBLIC_GOOGLE_MAPS_TOKEN=
